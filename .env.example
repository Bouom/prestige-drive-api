##======================================================================
## LCP VTC - Louer un Chauffeur Prestige API
## Environment Configuration
##======================================================================

APP_NAME="LCP VTC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

##----------------------------------------------------------------------
## Frontend
##----------------------------------------------------------------------

FRONTEND_URL=http://localhost:3000

##----------------------------------------------------------------------
## Logging
##----------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

##----------------------------------------------------------------------
## Database
##----------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lcp_vtc
DB_USERNAME=root
DB_PASSWORD=

##----------------------------------------------------------------------
## Session / Cache / Queue
##----------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=lcp_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

##----------------------------------------------------------------------
## Mail (set MAIL_MAILER=smtp for real email sending)
##----------------------------------------------------------------------

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@lcp-vtc.fr"
MAIL_FROM_NAME="${APP_NAME}"

##----------------------------------------------------------------------
## AWS / S3 (optional)
##----------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

##----------------------------------------------------------------------
## Laravel Passport (OAuth2)
##----------------------------------------------------------------------
## Run: php artisan passport:install
## Then fill in the generated client IDs and secrets below.

PASSPORT_PASSWORD_CLIENT_ID=
PASSPORT_PASSWORD_CLIENT_SECRET=
PASSPORT_SOCIAL_CLIENT_ID=
PASSPORT_SOCIAL_CLIENT_SECRET=
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

##----------------------------------------------------------------------
## Google OAuth
##----------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/google/callback"
APP_SCHEME=lcp-vtc://
CLIENT_BASE_URL="${FRONTEND_URL}"

##----------------------------------------------------------------------
## Google Maps / Location Services
##----------------------------------------------------------------------
## Set USE_OPENSTREETMAP=true to use free OSM/Nominatim/OSRM
## Set USE_OPENSTREETMAP=false and provide GOOGLE_MAPS_API_KEY for Google Maps

USE_OPENSTREETMAP=true
GOOGLE_MAPS_API_KEY=

##----------------------------------------------------------------------
## Stripe (Payments)
##----------------------------------------------------------------------

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300

##----------------------------------------------------------------------
## LCP Business Configuration
##----------------------------------------------------------------------

# Company Info
LCP_COMPANY_NAME="LCP VTC - Louer un Chauffeur Prestige"
LCP_COMPANY_EMAIL=contact@lcp-vtc.fr
LCP_COMPANY_PHONE="+33 1 23 45 67 89"
LCP_COMPANY_ADDRESS="Paris, France"
LCP_COMPANY_SIRET=
LCP_COMPANY_VAT=

# Ride Pricing
LCP_COMMISSION_RATE=15.0
LCP_CANCELLATION_FEE=5.00
LCP_MAX_DISTANCE_KM=500
LCP_DRIVER_SEARCH_RADIUS_KM=10
LCP_BASE_PRICE_PER_KM=2.50
LCP_MINIMUM_FARE=10.00
LCP_LONG_DISTANCE_THRESHOLD=100
LCP_LONG_DISTANCE_SURCHARGE=0
LCP_AVERAGE_SPEED_KMH=50

# Driver Settings
LCP_MIN_DRIVER_RATING=4.0
LCP_AUTO_ASSIGN_DRIVERS=true
LCP_DRIVER_ACCEPTANCE_TIMEOUT=300
LCP_MIN_ACCEPTANCE_RATE=80.0

# Payment Settings
LCP_CURRENCY=EUR
LCP_TAX_RATE=20.0
LCP_PAYMENT_GATEWAY=stripe
LCP_ALLOW_CASH_PAYMENTS=false
LCP_PAYOUT_FREQUENCY_DAYS=7

# Document Management
LCP_MAX_DOCUMENT_SIZE_MB=5
LCP_ALLOWED_DOCUMENT_TYPES=pdf,jpg,jpeg,png
LCP_DOCUMENT_EXPIRY_WARNING_DAYS=30

# Notifications
LCP_EMAIL_NOTIFICATIONS=true
LCP_SMS_NOTIFICATIONS=false
LCP_PUSH_NOTIFICATIONS=false

##----------------------------------------------------------------------
## Rate Limiting
##----------------------------------------------------------------------

RATE_LIMIT_PUBLIC=60
RATE_LIMIT_AUTHENTICATED=120
RATE_LIMIT_ADMIN=300

##----------------------------------------------------------------------
## Feature Flags
##----------------------------------------------------------------------

FEATURE_REALTIME_TRACKING=false
FEATURE_SCHEDULED_RIDES=true
FEATURE_MULTI_STOP=true
FEATURE_COMPANY_ACCOUNTS=true
FEATURE_REFERRALS=false
FEATURE_LOYALTY=false

##----------------------------------------------------------------------
## Vite (Frontend Assets)
##----------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"
